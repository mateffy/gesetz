{
  "name": "regel-workspace",
  "private": true,
  "workspaces": ["packages/*", "immoui"],
  "dependencies": {
    "@regeln/core": "workspace:*",
    "@regeln/effect-ts": "workspace:*",
    "@regeln/typescript": "workspace:*",
    "@regeln/junit": "workspace:*",
    "@regeln/vitest": "workspace:*",
    "@regeln/bun-test": "workspace:*",
    "@regeln/pest": "workspace:*",
    "@regeln/prettier": "workspace:*",
    "@regeln/oxfmt": "workspace:*",
    "@regeln/oxlint": "workspace:*",
    "@regeln/storybook": "workspace:*",
    "@regeln/phpunit": "workspace:*",
    "dependency-cruiser": "^18.0.0",
    "enhanced-resolve": "^5.24.1"
  },
  "scripts": {
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "build": "bun run --filter='@regeln/cli' build"
  }
}
