{
  "name": "gesetz-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@gesetz/bun-test": "workspace:*",
    "@gesetz/core": "workspace:*",
    "@gesetz/effect-ts": "workspace:*",
    "@gesetz/junit": "workspace:*",
    "@gesetz/oxfmt": "workspace:*",
    "@gesetz/oxlint": "workspace:*",
    "@gesetz/pest": "workspace:*",
    "@gesetz/phpunit": "workspace:*",
    "@gesetz/prettier": "workspace:*",
    "@gesetz/storybook": "workspace:*",
    "@gesetz/typescript": "workspace:*",
    "@gesetz/vitest": "workspace:*"
  },
  "scripts": {
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "build": "tsdown -W",
    "prepack": "tsdown -W",
    "publish": "pnpm -r publish --access public",
    "publint": "pnpm -r exec publint",
    "attw": "pnpm -r exec attw --pack"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3"
  }
}
