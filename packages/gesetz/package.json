{
  "name": "gesetz",
  "version": "1.3.1",
  "description": "Unified code-quality gate \u2014 core primitives and CLI. Install adapters separately.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "prepack": "tsdown"
  },
  "dependencies": {
    "@gesetz/cli": "workspace:*",
    "@gesetz/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "lint",
    "quality",
    "gate",
    "ci",
    "typescript",
    "rules"
  ],
  "license": "MIT",
  "author": "Lukas Mateffy <hey@mateffy.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateffy/gesetz.git"
  },
  "bugs": {
    "url": "https://github.com/mateffy/gesetz/issues"
  },
  "homepage": "https://github.com/mateffy/gesetz#readme",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
