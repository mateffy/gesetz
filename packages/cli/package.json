{
  "name": "@gesetz/cli",
  "version": "1.3.1",
  "type": "module",
  "bin": {
    "gesetz": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "prepack": "tsdown",
    "dev": "node --import tsx/esm src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@effect/cli": "^0.55.0",
    "@effect/platform": "^0.80.0",
    "@effect/platform-node": "^0.73.0",
    "@gesetz/core": "workspace:*",
    "@gesetz/typescript": "workspace:*",
    "@gesetz/php": "workspace:*",
    "effect": "^3.15.0"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
